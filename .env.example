# ============================================================
#  MAPS-VLA  –  secrets & cluster-specific configuration
#  Copy this file to secrets.env and fill in your values.
# ============================================================

# ---------- Cluster / SLURM ----------
SLURM_PARTITION="<your-partition>"
SLURM_EXCLUDE_NODES=""
HOME_OVERRIDE="/path/to/your/home"

# ---------- Conda environment ----------
CONDA_BASE_PATH="${HOME_OVERRIDE}/miniconda3"
CONDA_ENV_NAME="maps-vla"
PYTHON_BIN="${CONDA_BASE_PATH}/envs/${CONDA_ENV_NAME}/bin/python"

# ---------- Data & cache paths ----------
MAPS_DATA_ROOT="/path/to/datasets"
HUGGINGFACE_HUB_CACHE="/path/to/huggingface_cache"
MAPS_PROJECT_DIR="/path/to/projects/MAPS-VLA"

# ---------- HuggingFace ----------
HF_TOKEN=""

# ---------- Weights & Biases ----------
WANDB_ENTITY="<your-wandb-entity>"
WANDB_PROJECT="maps-vla"
# WANDB_API_KEY=""

# ---------- Google Gemini (optional, for analysis scripts) ----------
# GEMINI_API_KEY=""
